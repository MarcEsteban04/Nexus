{
  "name": "nexus",
  "version": "0.1.0",
  "description": "Nexus - Your Digital Life, Unified.",
  "main": "dist-electron/main.js",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"npm run dev\" \"npm run electron:compile:watch\" \"npm run electron:launch\"",
    "electron:compile:watch": "tsc -p electron -w --preserveWatchOutput",
    "electron:launch": "wait-on tcp:5173 dist-electron/main.js && electron .",
    "electron:build": "tsc -b && vite build && tsc -p electron && electron-builder"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^43.1.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "vite": "^6.0.1",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@fontsource/inter": "^5.3.0",
    "@fontsource/plus-jakarta-sans": "^5.3.0",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.25.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.1"
  }
}
